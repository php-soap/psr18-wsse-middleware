{
    "name": "php-soap/psr18-wsse-middleware",
    "description": "Adds WSSE security to your HTTP SOAP Transport",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Soap\\Psr18WsseMiddleware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SoapTest\\Psr18WsseMiddleware\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Toon Verwerft",
            "email": "toonverwerft@gmail.com"
        }
    ],
    "require": {
        "php": "~8.4.0 || ~8.5.0",
        "ext-dom": "*",
        "ext-openssl": "*",
        "php-standard-library/file": "^6.1",
        "php-standard-library/foundation": "^6.1",
        "php-standard-library/type": "^6.1",
        "paragonie/hidden-string": "^2.0",
        "php-soap/psr18-transport": "^2.0",
        "php-soap/engine": "^2.20",
        "php-soap/xml": "^1.10",
        "php-http/client-common": "^2.7",
        "robrichards/wse-php": "^2.0"
    },
    "require-dev": {
        "nyholm/psr7": "^1.5",
        "php-http/mock-client": "^1.5",
        "symfony/http-client": "^7.1",
        "phpunit/phpunit": "~12.3",
        "vimeo/psalm": "~6.13",
        "php-cs-fixer/shim": "~3.88",
        "cweagans/composer-patches": "^1.7"
    },
    "extra": {
        "patches": {
            "robrichards/wse-php": {
                "Fix encryption bug": "https://patch-diff.githubusercontent.com/raw/robrichards/wse-php/pull/67.diff"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "cweagans/composer-patches": true,
            "php-http/discovery": true
        }
    }
}
